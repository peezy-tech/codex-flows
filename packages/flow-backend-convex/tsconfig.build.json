{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": false,
		"noEmit": false,
		"noEmitOnError": true,
		"outDir": "dist",
		"paths": {},
		"rootDir": "src",
		"sourceMap": true,
		"rewriteRelativeImportExtensions": true
	},
	"include": ["src/**/*.ts"],
	"exclude": ["test/**/*.ts", "dist"]
}
